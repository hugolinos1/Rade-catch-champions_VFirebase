
rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Dossier spécifique pour les espèces, accessible par tous pour la lecture
    // Les écritures nécessitent d'être authentifié (y compris via sign-in anonyme)
    match /species/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Règle par défaut pour le reste du stockage (catches, profils)
    match /{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
