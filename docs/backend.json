
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a participant or administrator.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["participant", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "totalPoints": { "type": "number" },
        "catchesCount": { "type": "number" },
        "avatarUrl": { "type": "string", "format": "uri" }
      }
    },
    "FishSpecies": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "FishSpecies",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "scientificName": { "type": "string" },
        "description": { "type": "string" },
        "minSize": { "type": "number" },
        "pointsPerCm": { "type": "number" },
        "imageUrl": { "type": "string", "format": "uri" }
      }
    },
    "Catch": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Catch",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "fishId": { "type": "string" },
        "fishName": { "type": "string" },
        "length": { "type": "number" },
        "weight": { "type": "number" },
        "photoUrl": { "type": "string" },
        "timestamp": { "type": "string" },
        "points": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/User" },
      "description": "Collection des utilisateurs"
    },
    "/species/{speciesId}": {
      "schema": { "$ref": "#/backend/entities/FishSpecies" },
      "description": "Guide des poissons"
    },
    "/competitions/{competitionId}": {
      "schema": { "type": "object" },
      "description": "Concours de pêche"
    },
    "/catches/{catchId}": {
      "schema": { "$ref": "#/backend/entities/Catch" },
      "description": "Prises enregistrées"
    },
    "/registration_codes/{codeId}": {
      "schema": { "type": "object" },
      "description": "Codes d'invitation"
    }
  }
}
