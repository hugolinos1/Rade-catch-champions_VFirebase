// FORCE DEPLOYMENT: 2025-03-05T14:30:00Z
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // RÈGLES DE LECTURE PUBLIQUE
    // On autorise explicitement 'read' (get + list) pour toutes les collections clés.
    
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    match /species/{speciesId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    match /competitions/{competitionId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    match /catches/{catchId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    match /registration_codes/{codeId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Règle de secours universelle
    match /{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}