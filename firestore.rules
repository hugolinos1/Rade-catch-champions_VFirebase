// Last update: 2024-05-20T17:30:00Z - FORCED GLOBAL READ ACCESS
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // RÈGLE ABSOLUE : Autorise la lecture publique sur TOUS les documents.
    // Cela garantit que le classement, le guide et les flux de captures fonctionnent.
    match /{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Sécurité supplémentaire explicite pour les captures
    match /catches/{catchId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Sécurité supplémentaire explicite pour les utilisateurs
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}