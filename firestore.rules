// Last update: 2024-05-20T16:00:00Z - Global Read Access Fix
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // RÈGLE UNIVERSELLE DE LECTURE : On autorise la lecture publique sur TOUT
    // C'est nécessaire pour le classement en temps réel et le guide
    match /{document=**} {
      allow read: if true;
    }

    // ÉCRITURE : Autorisée pour tous les utilisateurs connectés
    // La validation se fait ensuite via l'interface Admin
    match /{document=**} {
      allow write: if request.auth != null;
    }
    
    // Exception pour les codes d'enregistrement : lecture publique aussi
    match /registration_codes/{code} {
      allow read: if true;
    }
  }
}