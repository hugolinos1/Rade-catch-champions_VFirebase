// FORCE DEPLOYMENT: 2025-03-05T22:30:00Z
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Lecture publique pour toutes les collections clés (indispensable pour le classement)
    match /catches/{catchId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    match /competitions/{compId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /species/{speciesId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /registration_codes/{codeId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Règle par défaut pour le reste
    match /{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}