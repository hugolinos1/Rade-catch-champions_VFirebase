// FORCE DEPLOYMENT: 2025-03-05T16:00:00Z
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Lecture publique autorisée pour toutes les collections principales
    // Cela garantit que le classement et le guide fonctionnent pour tous.
    match /users/{id} { allow read: if true; allow write: if request.auth != null; }
    match /species/{id} { allow read: if true; allow write: if request.auth != null; }
    match /catches/{id} { allow read: if true; allow write: if request.auth != null; }
    match /competitions/{id} { allow read: if true; allow write: if request.auth != null; }
    match /registration_codes/{id} { allow read: if true; allow write: if request.auth != null; }

    // Règle de secours universelle (Lecture pour tous, Écriture pour les authentifiés)
    match /{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}