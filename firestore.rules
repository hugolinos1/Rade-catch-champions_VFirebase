// Last update: 2024-05-20T14:30:00Z - Nuclear fix for permission errors
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ACCÈS TOTAL EN LECTURE POUR TOUT LE MONDE
    // On autorise la lecture (get et list) sur TOUTES les collections publiques
    match /catches/{id} { allow read: if true; }
    match /users/{id} { allow read: if true; }
    match /species/{id} { allow read: if true; }
    match /competitions/{id} { allow read: if true; }
    match /registration_codes/{id} { allow read: if true; }

    // ÉCRITURE : RÉSERVÉE AUX UTILISATEURS CONNECTÉS
    // On simplifie pour éviter les erreurs de contexte auth
    match /{collection}/{id} {
      allow write: if request.auth != null;
    }
  }
}