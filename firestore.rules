
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Fonctions de support
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // 1. CAPTURES : Lecture publique indispensable
    match /catches/{catchId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn(); // On simplifie pour éviter les erreurs de listage
    }

    // 2. UTILISATEURS : Lecture publique des profils pour les classements
    match /users/{userId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // 3. ESPÈCES (GUIDE) : Lecture publique
    match /species/{speciesId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // 4. CODES D'INVITATION
    match /registration_codes/{codeId} {
      allow read, write: if isSignedIn();
    }

    // 5. COMPÉTITIONS
    match /competitions/{competitionId} {
      allow read: if true;
      allow write: if isSignedIn();
    }
  }
}
