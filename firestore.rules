// FORCE DEPLOYMENT: 2024-05-21T10:00:00Z
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // RÈGLE UNIVERSELLE DE LECTURE : Autorise tout le monde à lire toutes les données.
    // Indispensable pour le classement, le guide et les flux de captures.
    match /{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}