// FORCE DEPLOYMENT: 2025-03-05T23:55:00Z
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Lecture publique et globale pour toutes les données essentielles au classement
    // Cette règle simplifiée élimine les erreurs de permission lors des requêtes complexes (list/queries)
    match /{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Sécurisation spécifique pour les codes d'invitation (optionnel mais recommandé)
    match /registration_codes/{codeId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}