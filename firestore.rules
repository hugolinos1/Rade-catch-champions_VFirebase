// FORCE DEPLOYMENT: 2025-03-06T10:00:00Z
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Lecture publique autorisée pour toutes les collections afin d'assurer le classement en temps réel
    match /{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}