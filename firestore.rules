// FORCE DEPLOYMENT: 2025-03-05T19:45:00Z
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Règle globale ultra-permissive pour la lecture afin de résoudre les erreurs de permission.
    // La lecture est publique pour toutes les collections (classement, guide, flux).
    match /{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}