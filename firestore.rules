rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Fonctions de support
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    // 1. CAPTURES : Lecture publique pour le classement et le flux en temps réel
    match /catches/{catchId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
    }

    // 2. UTILISATEURS : Lecture autorisée pour tous les membres (nécessaire pour le concours et classement)
    match /users/{userId} {
      allow get, list: if isSignedIn();
      allow create, update: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    // 3. ESPÈCES (GUIDE) : Lecture publique, modification Admin
    match /species/{speciesId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 4. CODES D'INVITATION : Gestion strictement réservée aux Admins
    match /registration_codes/{codeId} {
      // Permission de lecture unitaire pour la vérification lors de l'inscription
      allow get: if isSignedIn();
      // Listage et écriture réservés aux admins
      allow list, write: if isAdmin();
    }

    // 5. COMPÉTITIONS
    match /competitions/{competitionId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}