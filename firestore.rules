// FORCE DEPLOYMENT: 2025-03-05T21:15:00Z
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Règle globale simplifiée pour autoriser la lecture publique sur toutes les collections
    // Cela résout les erreurs de permission lors des listes (catches, users, species, etc.)
    match /{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}