rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * Rade Catch Champions - Security Rules
     * 
     * Strategy:
     * - Public: Read-only access to fish guide and active competitions.
     * - Authenticated: Can submit catches, manage their own profile, and list other members.
     * - Prototype Mode: Relaxed read permissions to simplify development and testing.
     * - Admin: Verified via /roles_admin collection.
     */

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- COLLECTION RULES ---

    match /users/{userId} {
      // Allow individual get for owner or admin
      allow get: if isOwner(userId) || isAdmin();
      // Relaxed list for prototype: allows selecting fishermen and viewing rankings
      allow list: if isSignedIn();
      // Users can manage their own profile
      allow create, update: if isOwner(userId);
      // Only admins can delete users
      allow delete: if isAdmin();
    }

    match /roles_admin/{userId} {
      // Needed for isAdmin() check to work on client and server
      allow read: if isSignedIn();
      allow write: if false; 
    }

    match /species/{speciesId} {
      // Guide is public
      allow get, list: if true; 
      // Prototyping: allow edits for any signed-in user for now
      allow create, update, delete: if isSignedIn();
    }

    match /competitions/{competitionId} {
      // Competition details are public
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /catches/{catchId} {
      // Publicly readable for rankings and history
      allow read: if true;
      
      // Owners can create their catches
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      
      // Admins can moderate, owners can update their own (if not approved/rejected yet)
      allow update: if isSignedIn() && (isAdmin() || (resource.data.userId == request.auth.uid && request.resource.data.userId == request.auth.uid));
      
      // Admins or owners can delete
      allow delete: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
    }

    match /registration_codes/{codeId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (isSignedIn() && resource.data.isUsed == false && request.resource.data.isUsed == true && request.resource.data.usedByUserId == request.auth.uid);
    }
  }
}